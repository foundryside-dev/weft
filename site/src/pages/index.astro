---
// ============================================================
// weft.foundryside.dev — the federation hub / landing.
//
// Orientation-only (IA §4.1): there is nothing called "weft" to
// install; the hub owns the interop layer (roster, axiom, matrix,
// SEI spine) and points at each member repo for that repo's surface
// facts. This page rebuilds the weft-federation kit's Site.jsx
// (Nav → Hero → Doctrine → Roster → Spine → Matrix → Lacuna → Footer)
// as a real Astro page driven entirely by @weft/site-kit data — NOT
// by the old window.WeftDesignSystem global.
//
// Everything that could disagree across the seven subdomains is
// sourced from the shared kit data (ROSTER / MATRIX / SEI_SPINE /
// FEDERATION_AXIOM) so the hub and the member sites cannot drift
// (IA §1.3, §3). No member is hardcoded here.
// ============================================================
import Layout from '@weft/site-kit/layouts/Layout.astro';
import { Button, Badge, Tag, Banner, MemberMark, SeiTag, EnrichmentChip } from '@weft/site-kit/components';
import {
  ROSTER,
  MATRIX,
  SEI_SPINE,
  FEDERATION_AXIOM,
  LACUNA,
  memberUrl,
  partnerOf,
  repoUrl,
} from '@weft/site-kit/data';

// "Build a member" points at the hub repo's federation SDK doc (IA §4.1).
const SDK_URL = `${repoUrl('weft')}/blob/main/federation-sdk.md`;
const LACUNA_URL = memberUrl('lacuna');

// Map a matrix pairing status to a Badge tone — honest, never rounded up
// ('partial'/'planned' are NEVER styled as 'live'; IA §2.2, §3.2).
const statusTone = (s) => (s === 'live' ? 'ok' : s === 'partial' ? 'warn' : 'neutral');
---

<Layout
  title="Weft — the tools are the threads, the weave is the product"
  description="The Weft federation documentation hub: a roster of sibling developer tools, each authoritative for one domain, each useful standalone, each composable pairwise — and enrich-only, never load-bearing."
>
  {/* ---------------------------------------------------------------- */}
  {/* 1 · Hero — axiom + dossier terminal (the honesty mechanic)       */}
  {/* ---------------------------------------------------------------- */}
  <section class="hero weft-weave">
    <div class="wrap">
      <p class="weft-eyebrow">The Weft federation · documentation hub</p>
      <h1 class="hero__title">The tools are the threads. The weave is the product.</h1>
      <p class="hero__tagline">One identity, woven through every tool.</p>
      <p class="hero__sub">
        Small, sharp developer tools, each authoritative for one domain and
        useful standalone, each composable pairwise — and
        <strong>enrich-only, never load-bearing</strong> when composed.
        No all-green dashboards; the seams are inspectable.
      </p>
      <div class="hero__cta">
        <Button client:idle as="a" href="#doctrine">Read the doctrine →</Button>
        <Button client:idle as="a" variant="secondary" href={SDK_URL} rel="noopener">Build a member →</Button>
      </div>

      {/* dossier terminal — one SEI, typed facts from every present peer.
          The brand refuses to show an all-green dossier: the hero mixes
          present / absent / unavailable on purpose (IA §3.4, §4.1). */}
      <div class="terminal">
        <div class="terminal__lines">
          <div><span class="terminal__prompt">$</span> weft dossier <span class="terminal__arg">build_record</span></div>
          <div class="terminal__dim">resolving entity → one SEI, typed facts from every present peer…</div>
        </div>
        <div class="terminal__chips">
          <SeiTag client:visible value={SEI_SPINE.sampleSei} copyable />
          <EnrichmentChip client:visible state="present" peer="loomweave" />
          <EnrichmentChip client:visible state="present" peer="wardline" />
          <EnrichmentChip client:visible state="present" peer="warpline" />
          <EnrichmentChip client:visible state="absent" peer="legis" />
          <EnrichmentChip client:visible state="unavailable" peer="plainweave" />
        </div>
      </div>
    </div>
  </section>

  {/* ---------------------------------------------------------------- */}
  {/* 2 · Doctrine / axiom — "documentation only, nothing to install"  */}
  {/* ---------------------------------------------------------------- */}
  <section id="doctrine" class="band">
    <div class="wrap">
      <p class="weft-eyebrow">Doctrine · the federation axiom</p>
      <h2 class="h2">Enrich-only, never load-bearing.</h2>
      <p class="lede">{FEDERATION_AXIOM}</p>
      <Banner client:visible tone="info" title="Documentation only — there is nothing called “weft” to install.">
        This hub owns the interop layer — the roster, the doctrine, the identity
        model, the matrix. It points to each member repo for that repo's surface
        facts (versions, tool counts, rule lists) and restates no moving number.
        Each member is its own tool, installed and used on its own; “weft” is the
        agreement that lets them compose.
      </Banner>
      {/* Suite-wide posture disclaimer — the deconfliction-not-security/compliance
          invariant, stated once at the hub for the whole federation. Never rounded
          up; the misuse this refuses is treating the suite as a gate. */}
      <div class="doctrine__more">
        <Banner client:visible tone="danger" title="Not a security or compliance product.">
          The whole Weft suite is <strong>deconfliction-first, not a security or
          compliance product</strong>. Most members are read-only, advisory, and
          enrich-only — they surface facts; they do not block, certify, or authorize.
          Legis, the governance thread, is the one that <em>can</em> gate, but only on
          the graded policy you configure, and even it is <strong>low-security by
          design</strong> — an attributable, tamper-evident record, never a security
          boundary and never a compliance verdict. Do not treat any seam here as access
          control, and do not use these tools for secure, regulated, confidential, or
          business-sensitive data.
        </Banner>
      </div>
    </div>
  </section>

  {/* ---------------------------------------------------------------- */}
  {/* 3 · Roster — the six threads (sourced from ROSTER)               */}
  {/* ---------------------------------------------------------------- */}
  <section id="roster" class="section">
    <div class="wrap">
      <p class="weft-eyebrow">The roster · six threads</p>
      <h2 class="h2">Each member owns one domain, and one thread color.</h2>
      <div class="grid grid--3">
        {ROSTER.map((m) => {
          const planned = m.status === 'planned';
          const Card = planned ? 'article' : 'a';
          const cardProps = planned
            ? { class: 'card card--member is-planned' }
            : { class: 'card card--member', href: m.url };
          return (
            <Card {...cardProps}>
              <span class="card__stripe" style={`background:${m.thread}`}></span>
              <div class="card__body">
                <div class="card__head">
                  <MemberMark client:visible member={m.key} size="lg" />
                  <span class="card__lang"><Tag client:visible>{m.lang}</Tag></span>
                </div>
                <div class="card__badge">
                  {planned ? (
                    <Badge client:visible tone="absent">planned</Badge>
                  ) : (
                    <Badge client:visible tone="neutral">{m.domain}</Badge>
                  )}
                </div>
                <p class="card__line">{m.tagline}</p>
                {!planned && <span class="card__more">{m.key}.foundryside.dev →</span>}
                {planned && <span class="card__more card__more--muted">no site yet — federation adapters planned</span>}
              </div>
            </Card>
          );
        })}
      </div>
    </div>
  </section>

  {/* ---------------------------------------------------------------- */}
  {/* 4 · SEI spine — one durable identity, facts survive the rename   */}
  {/* ---------------------------------------------------------------- */}
  <section id="spine" class="band">
    <div class="wrap">
      <p class="weft-eyebrow">{SEI_SPINE.eyebrow}</p>
      <h2 class="h2">{SEI_SPINE.heading}</h2>
      <p class="lede">{SEI_SPINE.body}</p>

      <div class="spine">
        <div class="spine__entity">
          <div class="spine__cap">entity</div>
          <SeiTag client:visible value={SEI_SPINE.sampleSei} copyable />
        </div>
        <div class="spine__arrow" aria-hidden="true">→</div>
        <div class="spine__facts">
          <div class="spine__cap">typed facts · one call</div>
          <div class="spine__rows">
            {SEI_SPINE.typedFacts.map((f) => (
              <div class="spine__row">
                <MemberMark client:visible member={f.peer} />
                <span class="spine__fact">{f.fact}</span>
                <EnrichmentChip client:visible state={f.state} />
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="vocab">
        {SEI_SPINE.enrichmentVocab.map((v) => (
          <div class="vocab__item">
            <EnrichmentChip client:visible state={v.state} />
            <span class="vocab__meaning">{v.meaning}</span>
          </div>
        ))}
      </div>

      <ul class="spine__notes">
        {SEI_SPINE.facts.map((fact) => <li>{fact}</li>)}
      </ul>
    </div>
  </section>

  {/* ---------------------------------------------------------------- */}
  {/* 5 · Combination matrix — the cross-link spine (sourced MATRIX)   */}
  {/* ---------------------------------------------------------------- */}
  <section id="matrix" class="section">
    <div class="wrap">
      <p class="weft-eyebrow">The combination matrix · value is the weave</p>
      <h2 class="h2">Each pair lights up a capability neither tool has alone.</h2>
      <p class="lede">
        One non-conformant binding orphans every combination it participates in —
        so the matrix is also the conformance test. Every pairing's status is
        honest on its face; a <code>partial</code> or <code>planned</code> pair is
        never rendered as <code>live</code>.
      </p>

      <div class="grid grid--2">
        {MATRIX.map((p) => {
          // The MemberMark for each partner links cross-subdomain — the matrix
          // IS the sanctioned cross-link channel (IA §2.2, §2.3).
          const aUrl = memberUrl(p.a);
          const bUrl = memberUrl(p.b);
          return (
            <article class="card card--pair">
              <div class="pair__head">
                <a class="pair__mark" href={aUrl}><MemberMark client:visible member={p.a} /></a>
                <span class="pair__plus" aria-hidden="true">+</span>
                <a class="pair__mark" href={bUrl}><MemberMark client:visible member={p.b} /></a>
                <span class="pair__status">
                  <Badge client:visible tone={statusTone(p.status)} dot>{p.status}</Badge>
                </span>
              </div>
              <p class="pair__cap">{p.capability}</p>
              {p.note && <p class="pair__note">{p.note}</p>}
            </article>
          );
        })}
      </div>

      <div class="matrix__higher">
        <Banner client:visible tone="info" title="Higher-order: all five close the loop.">
          The agent understands the code (Loomweave) and its trust posture
          (Wardline), Legis governs what it may do and records overrides, Warpline
          tracks how it changes over time (change-impact on the SEI spine), and
          every decision and unit of work is tracked against stable identity
          (Filigree + Loomweave). No single tool is load-bearing for another; each
          pair just makes the others sharper.
        </Banner>
      </div>
    </div>
  </section>

  {/* ---------------------------------------------------------------- */}
  {/* 6 · Lacuna strip — see it run on the specimen                    */}
  {/* ---------------------------------------------------------------- */}
  <section class="lacuna">
    <div class="wrap lacuna__inner">
      <span class="lacuna__dot" style={`background:${LACUNA.thread}`}></span>
      <div class="lacuna__copy">
        <p class="lacuna__lead">Want to see it actually run?</p>
        <p class="lacuna__sub">
          <code>make tour</code> the whole federation against <strong>Lacuna</strong>,
          the demonstration specimen — a small app with catalogued flaws, analyzed
          by every member at once.
        </p>
      </div>
      <span class="lacuna__cta">
        <Button client:idle as="a" variant="secondary" href={LACUNA_URL}>See it on the specimen →</Button>
      </span>
    </div>
  </section>
</Layout>

<style>
  /* Page-local layout. Brand atoms (colors, type, motifs) come ONLY from the
     site-kit token layer — no new colors, no dark mode (light theme only). */
  .wrap { max-width: var(--width-content); margin: 0 auto; padding: 0 36px; }
  .weft-eyebrow { margin: 0 0 14px; }
  .h2 { font: var(--type-h1); color: var(--text-strong); margin: 0 0 16px; max-width: 24ch; }
  .lede { font: var(--type-body); color: var(--text-body); max-width: 64ch; margin: 0 0 26px; }
  .lede code, .pair__cap code { font-family: var(--font-mono); font-size: 0.92em; color: var(--text-strong); }
  .doctrine__more { margin-top: 12px; }

  .section { padding: var(--space-10) 0; }
  .band {
    padding: var(--space-10) 0; background: var(--bg-sunken);
    border-top: 1px solid var(--border-hairline);
    border-bottom: 1px solid var(--border-hairline);
  }

  /* hero */
  .hero {
    padding: 78px 0 var(--space-10);
    border-bottom: 1px solid var(--border-hairline);
  }
  .hero__title {
    font: var(--type-display); color: var(--loom-900);
    letter-spacing: -0.025em; line-height: 1.05;
    max-width: 18ch; margin: 0 0 14px;
  }
  .hero__tagline {
    font: var(--type-body); font-size: var(--text-xl); font-weight: var(--fw-medium);
    color: var(--text-strong); max-width: 40ch; margin: 0 0 22px;
  }
  .hero__sub { font: var(--type-body); font-size: var(--text-lg); color: var(--text-body); max-width: 58ch; margin: 0 0 28px; }
  .hero__sub strong { color: var(--text-strong); }
  .hero__cta { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }

  .terminal {
    background: var(--surface-inverse); border-radius: var(--radius-lg);
    padding: 18px 20px; max-width: 720px; box-shadow: var(--shadow-lg);
  }
  .terminal__lines { font: var(--type-mono); color: var(--text-on-inverse); font-size: var(--text-xs); line-height: 1.7; }
  .terminal__prompt { color: var(--ash-500); }
  .terminal__arg { color: var(--indigo-300); }
  .terminal__dim { color: var(--ash-500); }
  .terminal__chips { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-top: 14px; }

  /* cards (shared) */
  .grid { display: grid; gap: 16px; }
  .grid--3 { grid-template-columns: repeat(3, 1fr); }
  .grid--2 { grid-template-columns: repeat(2, 1fr); }
  .card {
    background: var(--surface-card); border: 1px solid var(--border-hairline);
    border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-xs);
  }

  /* roster card */
  a.card--member { text-decoration: none; color: inherit; display: block; transition: box-shadow var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out); }
  a.card--member:hover { box-shadow: var(--shadow-lg); transform: translateY(-1px); }
  .card--member.is-planned { opacity: 0.85; }
  .card__stripe { display: block; height: 4px; width: 100%; }
  .card__body { padding: 18px; }
  .card__head { display: flex; align-items: center; margin-bottom: 12px; }
  .card__lang { margin-left: auto; }
  .card__badge { margin-bottom: 10px; }
  .card__line { font: var(--type-body-sm); color: var(--text-body); margin: 0 0 14px; }
  .card__more { font: var(--type-mono-sm); color: var(--indigo-700); }
  .card__more--muted { color: var(--text-faint); }

  /* spine */
  .spine { display: flex; align-items: stretch; gap: 14px; flex-wrap: wrap; margin-bottom: 24px; }
  .spine__entity, .spine__facts {
    background: var(--surface-card); border: 1px solid var(--border-hairline);
    border-radius: var(--radius-md); padding: 16px;
  }
  .spine__entity { flex: 1 1 220px; }
  .spine__facts { flex: 2 1 360px; }
  .spine__arrow { display: flex; align-items: center; color: var(--text-faint); font-size: 22px; }
  .spine__cap { font: var(--type-mono-sm); color: var(--text-faint); margin-bottom: 10px; }
  .spine__rows { display: flex; flex-direction: column; gap: 8px; }
  .spine__row { display: flex; align-items: center; gap: 10px; }
  .spine__fact { margin-left: auto; font: var(--type-mono-sm); color: var(--text-muted); }
  .spine__notes { margin: 0; padding-left: 18px; color: var(--text-muted); font: var(--type-body-sm); }
  .spine__notes li { margin: 6px 0; }

  .vocab {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px 18px;
    margin: 0 0 24px; padding: 16px;
    background: var(--surface-card); border: 1px solid var(--border-hairline); border-radius: var(--radius-md);
  }
  .vocab__item { display: flex; align-items: center; gap: 10px; }
  .vocab__meaning { font: var(--type-body-sm); color: var(--text-muted); }

  /* matrix pair card */
  .card--pair { padding: 16px; }
  .pair__head { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .pair__mark { text-decoration: none; }
  .pair__mark:hover { text-decoration: underline; text-underline-offset: 3px; }
  .pair__plus { color: var(--text-faint); font-family: var(--font-mono); }
  .pair__status { margin-left: auto; }
  .pair__cap { font: var(--type-body-sm); color: var(--text-body); margin: 0; }
  .pair__note { font: var(--type-mono-sm); color: var(--text-faint); margin: 8px 0 0; line-height: 1.5; }
  .matrix__higher { margin-top: 22px; }

  /* lacuna strip */
  .lacuna { padding: 40px 0; background: var(--bg-sunken); border-top: 1px solid var(--border-hairline); }
  .lacuna__inner { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .lacuna__dot { width: 12px; height: 12px; border-radius: var(--radius-sm); flex: none; box-shadow: inset 0 0 0 1px var(--border-hairline); }
  .lacuna__copy { flex: 1 1 360px; }
  .lacuna__lead { font: var(--type-body); font-weight: var(--fw-semibold); color: var(--text-strong); margin: 0 0 2px; }
  .lacuna__sub { font: var(--type-body-sm); color: var(--text-muted); margin: 0; }
  .lacuna__sub code { font-family: var(--font-mono); color: var(--text-strong); }
  .lacuna__cta { flex: none; }

  @media (max-width: 880px) {
    .grid--3, .grid--2, .vocab { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .wrap { padding: 0 18px; }
    .hero { padding: 56px 0 48px; }
  }
</style>

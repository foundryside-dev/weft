---
// Weft site-kit — global top navigation (IA §2.1).
// Sticky 60px header, hairline bottom border, linen at 85% + 8px
// blur. Brand → hub; a CSS-only `Tools ▾` dropdown listing every
// member as a MemberMark linking to its subdomain; Doctrine / Matrix
// / Lacuna anchors; a right cluster with MIT · org and a GitHub link.
//
// Cross-subdomain targets are ABSOLUTE https://{member}.foundryside.dev
// URLs (IA §2.2, §2.6). The dropdown and active-state are pure CSS —
// no JS (IA §2.1). Active member is marked via aria-current.
import { ROSTER, LACUNA, memberUrl } from '../data/roster.js';

export interface Props {
  /** The current site's member key, so its Tools entry reads active. Omit on the hub. */
  active?: string;
  /** The repo URL for THIS site's GitHub button. Defaults to the org. */
  repo?: string;
}

const { active, repo = 'https://github.com/foundryside-dev' } = Astro.props;
const HUB = 'https://weft.foundryside.dev/';

// Tools menu: the six roster members + Lacuna. No member is currently
// 'planned' (Plainweave is admitted and renders as a normal Tools link);
// the planned → disabled (no href) branch below is retained as defensive
// for any future planned member, per IA §2.3.
const toolItems = [...ROSTER, LACUNA];
---

<header class="wk-nav">
  <a class="wk-nav__brand" href={HUB} aria-label="Weft — federation hub">
    <img src="/_site-kit/weft-glyph.svg" width="24" height="24" alt="" class="wk-nav__glyph" />
    <span class="wk-nav__word">weft</span>
  </a>

  <nav class="wk-nav__primary" aria-label="Primary">
    <div class="wk-nav__tools">
      <button type="button" class="wk-nav__toolsbtn" aria-haspopup="true" aria-expanded="false">
        Tools <span aria-hidden="true">▾</span>
      </button>
      <div class="wk-nav__menu" role="menu">
        {toolItems.map((m) => {
          const isActive = m.key === active;
          const planned = m.status === 'planned';
          const common = {
            class: ['wk-nav__menuitem', isActive && 'is-active'].filter(Boolean).join(' '),
            role: 'menuitem',
            'aria-current': isActive ? 'page' : undefined,
          };
          return planned ? (
            <span {...common} aria-disabled="true" title="planned — no site yet">
              <span class="wk-member__dot" style={`background:${m.thread}`}></span>
              <span>{m.name}</span>
              <span class="wk-nav__plannedtag">planned</span>
            </span>
          ) : (
            <a {...common} href={m.url}>
              <span class="wk-member__dot" style={`background:${m.thread}`}></span>
              <span>{m.name}</span>
            </a>
          );
        })}
      </div>
    </div>

    <a class="wk-nav__link" href="https://weft.foundryside.dev/#doctrine">Doctrine</a>
    <a class="wk-nav__link" href="https://weft.foundryside.dev/#matrix">Matrix</a>
    <a class="wk-nav__link" href={memberUrl('lacuna')}>Lacuna</a>
  </nav>

  <div class="wk-nav__right">
    <span class="wk-nav__meta">MIT · foundryside-dev</span>
    <a class="wf-btn wf-btn--secondary wf-btn--sm" href={repo} rel="noopener">GitHub</a>
  </div>
</header>

<style>
  .wk-nav {
    position: sticky; top: 0; z-index: 50; height: 60px;
    display: flex; align-items: center; gap: 22px; padding: 0 36px;
    border-bottom: 1px solid var(--border-hairline);
    background: rgba(251, 248, 241, 0.85);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  }
  .wk-nav__brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .wk-nav__brand:hover { text-decoration: none; }
  .wk-nav__glyph { color: var(--indigo-600); }
  .wk-nav__word {
    font-family: var(--font-display); font-weight: 600; font-size: 21px;
    letter-spacing: -0.02em; color: var(--loom-900);
  }
  .wk-nav__primary { display: flex; align-items: center; gap: 20px; margin-left: 18px; }
  .wk-nav__link {
    font: var(--type-body-sm); color: var(--text-muted); font-weight: 500; text-decoration: none;
  }
  .wk-nav__link:hover { color: var(--text-body); text-decoration: none; }

  /* CSS-only dropdown — opens on hover and on keyboard focus-within (no JS) */
  .wk-nav__tools { position: relative; }
  .wk-nav__toolsbtn {
    appearance: none; border: 0; background: transparent; cursor: pointer;
    font: var(--type-body-sm); font-weight: 500; color: var(--text-muted);
    display: inline-flex; align-items: center; gap: 5px; padding: 0;
  }
  .wk-nav__toolsbtn:hover { color: var(--text-body); }
  .wk-nav__menu {
    position: absolute; top: calc(100% + 12px); left: 0; min-width: 200px;
    background: var(--surface-card); border: 1px solid var(--border-hairline);
    border-radius: var(--radius-md); box-shadow: var(--shadow-lg);
    padding: 6px; display: none; flex-direction: column; gap: 1px;
  }
  .wk-nav__tools:hover .wk-nav__menu,
  .wk-nav__tools:focus-within .wk-nav__menu { display: flex; }
  .wk-nav__menuitem {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-body);
    padding: 7px 9px; border-radius: var(--radius-sm); text-decoration: none;
  }
  a.wk-nav__menuitem:hover { background: var(--linen-100); text-decoration: none; }
  .wk-nav__menuitem.is-active { background: var(--indigo-50); color: var(--indigo-700); font-weight: 600; }
  .wk-nav__menuitem[aria-disabled='true'] { color: var(--text-faint); cursor: default; }
  .wk-member__dot {
    width: 9px; height: 9px; border-radius: 2px; flex: none;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.08);
  }
  .wk-nav__plannedtag {
    margin-left: auto; font-size: var(--text-2xs); color: var(--text-faint);
    border: 1px dashed var(--thread-400); border-radius: var(--radius-pill); padding: 1px 6px;
  }

  .wk-nav__right { margin-left: auto; display: flex; align-items: center; gap: 14px; }
  .wk-nav__meta { font: var(--type-mono-sm); color: var(--text-faint); }

  @media (max-width: 720px) {
    .wk-nav { padding: 0 18px; gap: 12px; }
    .wk-nav__meta { display: none; }
    .wk-nav__link { display: none; }
  }
</style>
